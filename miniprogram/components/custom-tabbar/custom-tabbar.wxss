.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-top: 1px solid #f0f0f0;
  padding: 6px 0;
  padding-bottom: calc(6px + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2px 20rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  padding: 8px 0;
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-icon {
  font-size: 24px;
  line-height: 1;
  transition: all 0.3s;
  position: relative;
}

.tab-label {
  font-size: 11px;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item .tab-icon,
.tab-item .tab-label {
  color: #999;
}

.tab-item.active .tab-icon,
.tab-item.active .tab-label {
  color: #667eea;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  background: #667eea;
  border-radius: 2px;
}

.tab-badge {
  position: absolute;
  top: -2px;
  right: 50%;
  transform: translateX(50%);
  background: #ef4444;
  color: white;
  font-size: 10px;
  font-weight: 600;
  min-width: 16px;
  height: 16px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
  animation: badgePulse 2s infinite;
}

@keyframes badgePulse {
  0%, 100% { transform: translateX(50%) scale(1); }
  50% { transform: translateX(50%) scale(1.1); }
}
