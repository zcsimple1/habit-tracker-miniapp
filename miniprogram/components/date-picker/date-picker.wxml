<view class="date-picker-wrapper">
  <view class="date-nav-btn" bindtap="onPrevDay">‹</view>
  <view class="date-display" bindtap="onOpenCalendar">
    <text class="date-text">{{displayDate}}</text>
    <text class="date-weekday">{{displayWeekday}}</text>
    <text class="date-badge {{isToday ? 'today' : 'history'}}">{{isToday ? '今天' : '查看'}}</text>
  </view>
  <view class="date-nav-btn" bindtap="onNextDay">›</view>
</view>
