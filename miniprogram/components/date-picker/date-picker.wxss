.date-picker-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.date-nav-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: none;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.date-nav-btn::after {
  border: none;
}

.date-display {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.25);
  cursor: pointer;
}

.date-display::after {
  border: none;
}

.date-text {
  font-size: 28rpx;
  color: white;
  font-weight: 600;
}

.date-weekday {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 4rpx;
}

.date-badge {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

.date-badge.today {
  background: rgba(255,255,255,0.4);
  color: white;
}

.date-badge.history {
  background: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.8);
}
