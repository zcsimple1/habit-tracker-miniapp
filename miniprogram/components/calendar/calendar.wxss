.calendar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.calendar-content {
  background: white;
  width: 100%;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.calendar-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.calendar-close {
  font-size: 56rpx;
  color: #999;
  line-height: 1;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 24rpx;
}

.calendar-weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.calendar-day {
  width: calc(100% / 7);
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333;
  border-radius: 16rpx;
  position: relative;
}

.calendar-day.other-month {
  color: #ccc;
}

.calendar-day.today {
  background: #f0f9ff;
  color: #667eea;
  font-weight: 600;
}

.calendar-day.selected {
  background: #667eea;
  color: white;
}

.calendar-dot {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #ef4444;
  border-radius: 50%;
}

.calendar-footer {
  display: flex;
  gap: 24rpx;
}

.calendar-nav-btn {
  flex: 1;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
}
