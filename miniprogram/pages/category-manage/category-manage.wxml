<view class="container">
  <!-- 头部 -->
  <view class="header">
    <button class="header-btn cancel" bindtap="onFinish">取消</button>
    <view class="header-title">管理分类</view>
    <view class="header-spacer"></view>
  </view>

  <!-- 内容区 -->
  <view class="content">
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading">
      <view class="loading-spinner"></view>
      <view class="loading-text">加载中...</view>
    </view>

    <!-- 新建分类按钮 -->
    <button wx:if="{{!loading}}" class="add-category-btn" bindtap="onAddCategory">
      <span style="font-size: 20px; color: white;">+</span>
      新建分类
    </button>

    <!-- 空状态 -->
    <view wx:if="{{!loading && customCategories.length === 0}}" class="empty-state">
      <view class="empty-icon">📁</view>
      <view class="empty-text">还没有自定义分类</view>
    </view>

    <!-- 预设分类列表 -->
    <view wx:if="{{!loading}}" class="section-title">预设分类</view>
    <view wx:for="{{presetCategories}}" wx:key="id" class="category-card">
      <view class="category-icon-box" style="background: {{item.color}};">{{item.icon}}</view>
      <view class="category-info">
        <view class="category-name">{{item.name}}</view>
        <view class="category-desc">预设分类</view>
      </view>
      <view class="category-actions">
        <button class="action-btn disabled">不可编辑</button>
      </view>
    </view>

    <!-- 自定义分类列表 -->
    <view wx:if="{{!loading && customCategories.length > 0}}" class="section-title">自定义分类</view>
    <view wx:for="{{customCategories}}" wx:key="_id" class="category-card">
      <view class="category-icon-box" style="background: {{item.color}};">{{item.icon}}</view>
      <view class="category-info">
        <view class="category-name">{{item.name}}</view>
        <view class="category-desc">{{item.stats && item.stats.activeHabits > 0 ? item.stats.activeHabits + ' 个项目' : '0 个项目'}}</view>
      </view>
      <view class="category-actions">
        <button class="action-btn" bindtap="onEditCategory" data-category-id="{{item._id}}">编辑</button>
        <button class="action-btn delete" bindtap="onDeleteCategory" data-category-id="{{item._id}}">删除</button>
      </view>
    </view>
  </view>
</view>
