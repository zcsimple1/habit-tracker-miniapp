.container {
  padding: 20rpx;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.add-box {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  gap: 10rpx;
}

.input {
  flex: 1;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.add-btn {
  padding: 20rpx 30rpx;
  background: #4f46e5;
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin: 0;
}

.add-btn[disabled] {
  background: #ccc;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.item.completed {
  opacity: 0.6;
}

.checkbox {
  margin-right: 15rpx;
}

.text {
  flex: 1;
  font-size: 30rpx;
}

.item.completed .text {
  text-decoration: line-through;
}

.delete-btn {
  padding: 10rpx 20rpx;
  background: #ef4444;
  color: white;
  border-radius: 6rpx;
  font-size: 24rpx;
  margin: 0;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
