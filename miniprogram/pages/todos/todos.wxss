.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40px;
}

/* 头部 */
.header {
  padding: 30rpx 32rpx 40rpx;
  padding-top: calc(100rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: white;
}

.add-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: none;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 1;
}

.add-btn::after {
  border: none;
}

/* 日期选择器 */
.date-picker-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.date-nav-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: none;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.date-nav-btn::after {
  border: none;
}

.date-display {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.25);
}

.date-display::after {
  border: none;
}

.date-text {
  font-size: 28rpx;
  color: white;
  font-weight: 600;
}

.date-weekday {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 4rpx;
}

.date-badge {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

.date-badge.today {
  background: rgba(255,255,255,0.4);
  color: white;
}

.date-badge.history {
  background: rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.8);
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}

.loading-spinner {
  width: 30px;
  height: 30px;
  border: 3px solid #f3f3f3;
  border-top: 3px solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 12px;
  color: #999;
  font-size: 14px;
}

/* 内容区 */
.content {
  padding: 20rpx;
}

/* 分组标题 */
.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.group-title:first-child {
  margin-top: 0;
}

.count {
  background: #f0f0f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* 待办卡片 */
.todo-card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.2s;
}

.todo-card:active {
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  transform: translateY(-2rpx);
}

/* 优先级左边框 */
.todo-card.priority-urgent {
  border-left: 6rpx solid #ef4444;
}

.todo-card.priority-high {
  border-left: 6rpx solid #f97316;
}

/* 复选框 */
.todo-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #ddd;
  border-radius: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.todo-checkbox:active {
  border-color: #667eea;
}

.todo-checkbox.checked {
  background: #10b981;
  border-color: #10b981;
}

.todo-checkbox.checked::after {
  content: '✓';
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

/* 待办内容 */
.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 优先级徽章 */
.priority-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #fef2f2;
  color: #ef4444;
}

/* 待办元信息 */
.todo-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: #999;
  flex-wrap: wrap;
}

.todo-date {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.todo-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.todo-time.urgent {
  color: #ef4444;
  font-weight: 500;
}

.todo-category {
  background: #f0f9ff;
  color: #667eea;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 重要标记 */
.todo-important {
  font-size: 28rpx;
  line-height: 1;
  flex-shrink: 0;
}

/* 已完成状态 */
.todo-card.completed {
  opacity: 0.6;
}

.todo-card.completed .todo-title {
  text-decoration: line-through;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  display: block;
}

.text {
  font-size: 28rpx;
  margin-bottom: 40rpx;
  display: block;
}

.empty-state button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  border: none;
  font-size: 28rpx;
}

.empty-state button::after {
  border: none;
}

/* 日历弹窗 */
.calendar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.calendar-content {
  background: white;
  width: 100%;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.calendar-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.calendar-close {
  font-size: 56rpx;
  color: #999;
  line-height: 1;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 24rpx;
}

.calendar-weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.calendar-day {
  width: calc(100% / 7);
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333;
  border-radius: 16rpx;
  position: relative;
}

.calendar-day.other-month {
  color: #ccc;
}

.calendar-day.today {
  background: #f0f9ff;
  color: #667eea;
  font-weight: 600;
}

.calendar-day.selected {
  background: #667eea;
  color: white;
}

/* 红点标记 */
.calendar-dot {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #ef4444;
  border-radius: 50%;
}

.calendar-footer {
  display: flex;
  gap: 24rpx;
}

.calendar-nav-btn {
  flex: 1;
  padding: 24rpx;
  background: #f5f5f5;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.calendar-nav-btn::after {
  border: none;
}
