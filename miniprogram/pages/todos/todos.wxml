<view class="container">
  <!-- 头部 -->
  <view class="header">
    <!-- 标题栏 -->
    <view class="header-top">
      <view class="header-title">今日待办</view>
    </view>

    <!-- 日期选择器 -->
    <view class="date-picker-container">
      <view class="date-nav-btn" bindtap="onPrevDay">‹</view>
      <view class="date-display" bindtap="onOpenCalendar">
        <text class="date-main">{{dateMain}}</text>
        <view class="date-row">
          <text class="date-weekday">{{dateWeekday}}</text>
          <text wx:if="{{isToday}}" class="today-badge">今天</text>
        </view>
      </view>
      <view class="date-nav-btn" bindtap="onNextDay">›</view>
    </view>

    <!-- 操作按钮 -->
    <view class="header-controls">
      <view class="action-buttons">
        <view class="eye-btn {{tempShowCompleted ? '' : 'closed'}}" bindtap="toggleShowCompleted">
          <image class="eye-icon eye-open" src="/images/eye-open.svg" mode="aspectFit"></image>
          <image class="eye-icon eye-closed" src="/images/eye-closed.svg" mode="aspectFit"></image>
        </view>
        <view wx:if="{{overdueTodos.length > 0}}" class="delete-overdue-btn" bindtap="onDeleteOverdueTodos">
          <text class="delete-icon">×</text>
        </view>
        <button class="add-todo-btn" bindtap="onAddTodo">+</button>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 内容区 -->
  <view wx:if="{{!loading}}" class="content">
    <!-- 今日 -->
    <view wx:if="{{todayTodos.length > 0}}" class="today-section">
      <view class="group-title">
        <text>📋 今日</text>
        <text class="count">{{todayTodos.length}}</text>
      </view>
      <view class="today-items">
        <view
          wx:for="{{todayTodos}}"
          wx:key="_id"
          class="todo-card {{item.priority === 'high' || item.priority === 'urgent' ? 'priority-high' : ''}}"
          bindlongpress="onEditTodo"
          data-todo-id="{{item._id}}"
        >
          <view class="todo-checkbox {{item.completed ? 'checked' : ''}}" bindtap="onToggleTodo" data-todo-id="{{item._id}}"></view>
          <view class="todo-content">
            <view class="todo-title">
              {{item.title}}
              <text wx:if="{{item.priority === 'urgent' || item.priority === 'high'}}" class="priority-badge">重要</text>
              <text wx:if="{{item.important}}" class="important-flag-text">🚩</text>
            </view>
            <view class="todo-meta">
              <text wx:if="{{item.dueTime}}" class="todo-time">
                ⏰ {{item.dueTime}}
              </text>
            </view>
          </view>
          <!-- 编辑删除按钮 -->
          <view class="todo-actions">
            <text class="action-btn edit-btn" bindtap="onEditTodo" data-todo-id="{{item._id}}">✎</text>
            <text class="action-btn delete-btn" bindtap="onDeleteTodo" data-todo-id="{{item._id}}">🗑</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 隐藏提示 -->
    <view wx:if="{{!tempShowCompleted && (futureTodos.length > 0 || overdueTodos.length > 0 || completedTodos.length > 0)}}" class="hidden-hint" bindtap="toggleShowCompleted">
      <view class="hint-title">已隐藏部分内容（点击显示所有）：</view>
      <view class="hint-content">
        <text wx:if="{{futureTodos.length > 0}}" class="hint-item">将来 <text class="hint-count">{{futureTodos.length}}</text> 项</text>
        <text wx:if="{{futureTodos.length > 0 && (overdueTodos.length > 0 || completedTodos.length > 0)}}" class="hint-sep">，</text>
        <text wx:if="{{overdueTodos.length > 0}}" class="hint-item">已过期 <text class="hint-count">{{overdueTodos.length}}</text> 项</text>
        <text wx:if="{{overdueTodos.length > 0 && completedTodos.length > 0}}" class="hint-sep">，</text>
        <text wx:if="{{completedTodos.length > 0}}" class="hint-item">已完成 <text class="hint-count">{{completedTodos.length}}</text> 项</text>
      </view>
    </view>

    <!-- 将来 -->
    <view wx:if="{{futureTodos.length > 0 && tempShowCompleted}}" class="future-section">
      <view class="group-title">
        <text>📅 将来</text>
        <text class="count">{{futureTodos.length}}</text>
      </view>
      <view class="future-items">
        <view
          wx:for="{{futureTodos}}"
          wx:key="_id"
          class="todo-card"
          bindlongpress="onEditTodo"
          data-todo-id="{{item._id}}"
        >
          <view class="todo-checkbox {{item.completed ? 'checked' : ''}}" bindtap="onToggleTodo" data-todo-id="{{item._id}}"></view>
          <view class="todo-content">
            <view class="todo-title">
              {{item.title}}
              <text wx:if="{{item.important}}" class="important-flag-text">🚩</text>
            </view>
            <view class="todo-meta">
              <text wx:if="{{item.dueDate}}" class="todo-date">
                📅 {{item.dueDate}}
              </text>
              <text wx:if="{{item.dueTime}}" class="todo-time">
                ⏰ {{item.dueTime}}
              </text>
            </view>
          </view>
          <!-- 编辑删除按钮 -->
          <view class="todo-actions">
            <text class="action-btn edit-btn" bindtap="onEditTodo" data-todo-id="{{item._id}}">✎</text>
            <text class="action-btn delete-btn" bindtap="onDeleteTodo" data-todo-id="{{item._id}}">🗑</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 已过期 -->
    <view wx:if="{{overdueTodos.length > 0 && tempShowCompleted}}" class="overdue-section">
      <view class="group-title">
        <text>⚠️ 已过期</text>
        <text class="count">{{overdueTodos.length}}</text>
      </view>
      <view class="overdue-items">
        <view
          wx:for="{{overdueTodos}}"
          wx:key="_id"
          class="todo-card overdue"
          bindlongpress="onEditTodo"
          data-todo-id="{{item._id}}"
        >
          <view class="todo-checkbox {{item.completed ? 'checked' : ''}}" bindtap="onToggleTodo" data-todo-id="{{item._id}}"></view>
          <view class="todo-content">
            <view class="todo-title">
              {{item.title}}
              <text wx:if="{{item.important}}" class="important-flag-text">🚩</text>
            </view>
            <view class="todo-meta">
              <text wx:if="{{item.dueDate}}" class="todo-date">
                📅 {{item.dueDate}}
              </text>
              <text wx:if="{{item.dueTime}}" class="todo-time">
                ⏰ {{item.dueTime}}
              </text>
            </view>
          </view>
          <!-- 编辑删除按钮 -->
          <view class="todo-actions">
            <text class="action-btn edit-btn" bindtap="onEditTodo" data-todo-id="{{item._id}}">✎</text>
            <text class="action-btn delete-btn" bindtap="onDeleteTodo" data-todo-id="{{item._id}}">🗑</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 已完成 -->
    <view wx:if="{{completedTodos.length > 0 && tempShowCompleted}}" class="completed-section">
      <view class="group-title">
        <text>✓ 已完成</text>
        <text class="count">{{completedTodos.length}}</text>
      </view>
      <view class="completed-items">
        <view
          wx:for="{{completedTodos}}"
          wx:key="_id"
          class="todo-card completed"
          bindlongpress="onEditTodo"
          data-todo-id="{{item._id}}"
        >
          <view class="todo-checkbox checked" bindtap="onToggleTodo" data-todo-id="{{item._id}}"></view>
          <view class="todo-content">
            <view class="todo-title">
              {{item.title}}
              <text wx:if="{{item.important}}" class="important-flag-text">🚩</text>
            </view>
            <view class="todo-meta">
              <text wx:if="{{item.dueDate}}" class="todo-date">
                📅 {{item.dueDate}}
              </text>
              <text wx:if="{{item.dueTime}}" class="todo-time">
                ⏰ {{item.dueTime}}
              </text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{todayTodos.length === 0 && futureTodos.length === 0 && overdueTodos.length === 0 && completedTodos.length === 0}}" class="empty-state">
      <text class="emoji">📝</text>
      <text class="text">今天还没有待办事项</text>
      <button bindtap="onAddTodo">添加待办</button>
    </view>
  </view>

  <!-- 日历弹窗 -->
  <view wx:if="{{showCalendar}}" class="calendar-modal" bindtap="onCloseCalendar">
    <view class="calendar-content" catchtap="onCalendarContentTap">
      <view class="calendar-header">
        <text class="calendar-month">{{calendarYear}}年{{calendarMonth + 1}}月</text>
        <text class="calendar-close" bindtap="onCloseCalendar">×</text>
      </view>
      <view class="calendar-weekdays">
        <text class="calendar-weekday">日</text>
        <text class="calendar-weekday">一</text>
        <text class="calendar-weekday">二</text>
        <text class="calendar-weekday">三</text>
        <text class="calendar-weekday">四</text>
        <text class="calendar-weekday">五</text>
        <text class="calendar-weekday">六</text>
      </view>
      <view class="calendar-days">
      <view
        wx:for="{{calendarDays}}"
        wx:key="index"
        class="calendar-day {{item.isOtherMonth ? 'other-month' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
        bindtap="onSelectDate"
        data-index="{{index}}"
      >
        {{item.day}}
        <view wx:if="{{item.hasTodo && !item.isOtherMonth}}" class="calendar-dot"></view>
      </view>
      </view>
      <view class="calendar-footer">
        <view class="calendar-nav-btn" catchtap="onMonthChange" data-delta="-1">上个月</view>
        <view class="calendar-nav-btn" catchtap="onMonthChange" data-delta="1">下个月</view>
      </view>
    </view>
  </view>

  <!-- 自定义底部导航 -->
  <custom-tabbar currentPage="pages/todos/todos" />
</view>
