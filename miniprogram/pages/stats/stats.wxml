<view class="card">
  <view class="row">
    <view class="title">统计概览</view>
    <button size="mini" bindtap="refresh">刷新</button>
  </view>
  <view class="muted" style="margin-top: 12rpx;">基于本地记录计算：连续天数、近7天、本周、本月。</view>
</view>

<block wx:if="{{rows.length === 0}}">
  <view class="card"><view class="muted">还没有习惯数据。</view></view>
</block>

<block wx:for="{{rows}}" wx:key="id">
  <view class="card">
    <view style="font-size: 32rpx; font-weight: 600;">{{item.name}}</view>
    <view class="muted" style="margin-top: 8rpx;">连续：{{item.streak}} 天</view>
    <view class="muted">近7天：{{item.last7.done}}/{{item.last7.total}}（{{item.last7.rate}}%）</view>
    <view class="muted">本周：{{item.week.done}}/{{item.week.total}}（{{item.week.rate}}%）</view>
    <view class="muted">本月完成：{{item.monthCount}} 天</view>
  </view>
</block>
