<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-title">📊 统计中心</view>
    <view class="date-tabs">
      <view 
        wx:for="{{['本周', '本月', '本年']}}"
        wx:key="index"
        class="date-tab {{dateRange === ['week','month','year'][index] ? 'active' : ''}}"
        bindtap="onDateRangeChange"
        data-range="{{['week','month','year'][index]}}"
      >{{item}}</view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 内容区 -->
  <view wx:if="{{!loading}}" class="content">
    <!-- 总体概况 -->
    <view class="section">
      <view class="section-title">📊 总体概况</view>
      <view class="overview-card">
        <view class="overview-row">
          <span class="overview-label">本月完成率</span>
          <span class="overview-value">{{overview.rangeRate}}%</span>
        </view>
        <view class="overview-row">
          <span class="overview-label">总打卡次数</span>
          <span class="overview-value">{{overview.totalCheckins}} 次</span>
        </view>
        <view class="overview-row">
          <span class="overview-label">活跃天数</span>
          <span class="overview-value">{{overview.activeDays}} 天</span>
        </view>
        <view class="overview-row">
          <span class="overview-label">今日完成</span>
          <span class="overview-value">{{overview.todayCompleted}}/{{overview.todayTotal}}</span>
        </view>
      </view>
    </view>

    <!-- 完成率排行 -->
    <view wx:if="{{ranking.length > 0}}" class="section">
      <view class="section-title">🏆 完成率排行</view>
      <view class="ranking-list">
        <view 
          wx:for="{{ranking}}" 
          wx:key="habitId"
          class="ranking-item"
        >
          <view class="rank-badge rank-{{index < 3 ? index + 1 : 'other'}}">{{index + 1}}</view>
          <view class="rank-info">
            <view class="rank-name">{{item.habitName}}</view>
            <view class="rank-category">{{item.categoryName}}</view>
          </view>
          <view class="rank-rate">{{item.rate}}次</view>
        </view>
      </view>
    </view>

    <!-- 按分类查看 -->
    <view wx:if="{{categoryStats.length > 0}}" class="section">
      <view class="section-title">📂 按分类查看</view>
      <view class="category-list">
        <view 
          wx:for="{{categoryStats}}" 
          wx:key="categoryId"
          class="category-stat"
        >
          <view class="category-icon" style="background-color: {{item.categoryColor}}20; color: {{item.categoryColor}}">
            {{item.categoryIcon}}
          </view>
          <view class="category-info">
            <view class="category-name">{{item.categoryName}}</view>
            <view class="category-detail">{{item.completed}}/{{item.total}} 项</view>
          </view>
          <view class="category-rate" style="color: {{item.categoryColor}}">{{item.rate}}%</view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{overview.totalHabits === 0}}" class="empty-state">
      <view class="empty-icon">📊</view>
      <view class="empty-text">还没有打卡记录</view>
      <view class="empty-desc">开始第一个习惯，积累你的数据吧</view>
    </view>
  </view>

  <!-- 自定义底部导航 -->
  <custom-tabbar currentPage="pages/stats/stats" />
</view>
