/* 统计页面样式 */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 头部 - 与首页保持一致 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 120rpx 30rpx 20rpx;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
  color: white;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 24rpx;
}

.date-tabs {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.date-tab {
  padding: 12rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 26rpx;
  transition: all 0.3s;
}

.date-tab.active {
  background: white;
  color: #667eea;
  font-weight: 600;
}

/* 内容区 */
.content {
  padding: 24rpx;
}

/* 区块 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 总体概况卡片 */
.overview-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.overview-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.overview-row:last-child {
  border-bottom: none;
}

.overview-label {
  font-size: 28rpx;
  color: #666;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #667eea;
}

/* 排行列表 */
.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.rank-badge.rank-1 { 
  background: linear-gradient(135deg, #ffd700, #ffb347); 
  color: white; 
}
.rank-badge.rank-2 { 
  background: linear-gradient(135deg, #c0c0c0, #e8e8e8); 
  color: white; 
}
.rank-badge.rank-3 { 
  background: linear-gradient(135deg, #cd7f32, #daa520); 
  color: white; 
}
.rank-badge.rank-other { 
  background: #f0f0f0; 
  color: #999; 
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.rank-category {
  font-size: 24rpx;
  color: #999;
}

.rank-rate {
  font-size: 32rpx;
  font-weight: 600;
  color: #10b981;
  flex-shrink: 0;
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-stat {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.category-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.category-detail {
  font-size: 24rpx;
  color: #999;
}

.category-rate {
  font-size: 36rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}
