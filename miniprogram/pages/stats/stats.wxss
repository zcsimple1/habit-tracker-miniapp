.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 120rpx 30rpx 20rpx;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: white;
}

/* 日期范围选择 */
.date-range-bar {
  background: white;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.date-range-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.range-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.arrow {
  font-size: 20rpx;
  color: #999;
}

.custom-date {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-picker {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.date-separator {
  font-size: 24rpx;
  color: #999;
}

/* 区块 */
.section {
  margin-top: 20rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

/* 总体概况 */
.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.overview-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.card-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.card-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.card-sub {
  font-size: 22rpx;
  color: #999;
}

/* 分类统计 */
.category-stats-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-stat-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-stat-item:last-child {
  border-bottom: none;
}

.category-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.category-progress {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #f5f5f5;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

/* 排行榜 */
.ranking-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-index {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.ranking-item:nth-child(1) .ranking-index {
  background: linear-gradient(135deg, #ffd700 0%, #ffb700 100%);
  color: white;
}

.ranking-item:nth-child(2) .ranking-index {
  background: linear-gradient(135deg, #c0c0c0 0%, #a8a8a8 100%);
  color: white;
}

.ranking-item:nth-child(3) .ranking-index {
  background: linear-gradient(135deg, #cd7f32 0%, #b87333 100%);
  color: white;
}

.ranking-item:nth-child(n+4) .ranking-index {
  background: #f5f5f5;
  color: #999;
}

.ranking-info {
  flex: 1;
  min-width: 0;
}

.ranking-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.ranking-category {
  font-size: 22rpx;
  color: #999;
}

.ranking-rate {
  text-align: right;
  flex-shrink: 0;
}

.rate-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 4rpx;
}

.rate-count {
  font-size: 20rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  margin-top: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #ccc;
}
