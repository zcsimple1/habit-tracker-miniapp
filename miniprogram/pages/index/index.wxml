<view class="container">
  <!-- 头部 -->
  <view class="header">
    <!-- 标题栏 -->
    <view class="header-top">
      <view class="header-title">今日打卡</view>
    </view>

    <!-- 日期选择器 -->
    <view class="date-picker-container">
      <view class="date-nav-btn" bindtap="onPrevDay">‹</view>
      <view class="date-display" bindtap="onChooseDate">
        <text class="date-main">{{dateMain}}</text>
        <view class="date-row">
          <text class="date-weekday">{{dateWeekday}}</text>
          <text wx:if="{{isToday}}" class="today-badge">今天</text>
        </view>
      </view>
      <view class="date-nav-btn" bindtap="onNextDay">›</view>
    </view>

    <!-- 模式切换和操作按钮 -->
    <view class="header-controls">
      <view class="view-toggle">
        <view class="toggle-btn {{viewMode === 'category' ? 'active' : ''}}" bindtap="toggleViewMode">
          📋 分类模式
        </view>
        <view class="toggle-btn {{viewMode === 'time' ? 'active' : ''}}" bindtap="toggleViewMode">
          📅 时间模式
        </view>
      </view>
      <view class="action-buttons">
        <view class="eye-btn {{tempShowCompleted ? '' : 'closed'}}" bindtap="toggleShowCompleted">
          <image class="eye-icon eye-open" src="/images/eye-open.svg" mode="aspectFit"></image>
          <image class="eye-icon eye-closed" src="/images/eye-closed.svg" mode="aspectFit"></image>
        </view>
        <button class="add-habit-btn" bindtap="onAddHabit">+</button>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <!-- 分类模式 -->
  <view wx:if="{{viewMode === 'category' && !loading}}" class="content">
    <view wx:if="{{categoryGroups.length === 0}}" class="empty-state">
      <view class="empty-icon">📋</view>
      <view class="empty-text">还没有习惯</view>
      <view class="empty-desc">开始添加第一个习惯吧</view>
      <button class="empty-btn" bindtap="onAddHabit">添加习惯</button>
    </view>
    <view wx:for="{{categoryGroups}}" wx:key="_id" class="category-card {{!item.expanded ? 'collapsed' : ''}}" data-category-id="{{item._id}}">
      <!-- 分类标题 -->
      <view class="category-header" bindtap="onToggleCategory" data-category-id="{{item._id}}">
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
        <text class="category-count">{{item.completed}}/{{item.total}}</text>
        <text class="category-arrow">{{item.expanded ? '▼' : '▶'}}</text>
      </view>
      
      <!-- 习惯列表 -->
      <view class="category-items" wx:if="{{item.expanded}}">
        <view wx:for="{{item.habits}}" wx:for-item="habit" wx:key="_id"
              class="habit-item {{habit.checked ? 'checked' : ''}} {{!tempShowCompleted && habit.checked ? 'hidden-item' : ''}}"
              data-habit-id="{{habit._id}}">
          <!-- 复选框 -->
          <view class="habit-checkbox {{habit.checked ? 'checked' : ''}}"
                bindtap="{{habit.checked ? 'onUncheckin' : 'onCheckin'}}"
                data-habit-id="{{habit._id}}">
            {{habit.checked ? '✓' : ''}}
          </view>

          <!-- 内容 -->
          <view class="habit-content">
            <text class="habit-name">{{habit.name}} <text class="important-flag-text" wx:if="{{habit.important}}">🚩</text></text>
            <view class="habit-meta">
              <text class="habit-time {{habit.timeRule && habit.timeRule.fixedTime ? 'has-time' : ''}}" wx:if="{{habit.timeRule && habit.timeRule.fixedTime}}">{{habit.timeRule.fixedTime}}</text>
              <text class="habit-time no-time" wx:else>无固定时间</text>
              <view wx:if="{{habit.totalCheckins > 0}}" class="streak-badge">
                🔥 {{habit.totalCheckins}}天
              </view>
            </view>
          </view>

          <!-- 编辑删除按钮 -->
          <view class="habit-actions">
            <text class="action-btn edit-btn" bindtap="onEditHabit" data-habit-id="{{habit._id}}">✎</text>
            <text class="action-btn delete-btn" bindtap="onDeleteHabit" data-habit-id="{{habit._id}}">🗑</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 时间模式 -->
  <view wx:if="{{viewMode === 'time' && !loading}}" class="content">
    <view wx:if="{{timeHabits.length === 0}}" class="empty-state">
      <view class="empty-icon">📅</view>
      <view class="empty-text">还没有习惯</view>
      <view class="empty-desc">开始添加第一个习惯吧</view>
      <button class="empty-btn" bindtap="onAddHabit">添加习惯</button>
    </view>
    <block wx:else>
      <!-- 总体统计 -->
      <view class="total-stats">
        已完成 <text class="done-count">{{todayStats.completed}}</text>/<text class="total-count">{{todayStats.total}}</text> 项
      </view>

      <!-- 习惯列表 -->
      <view wx:for="{{timeHabits}}" wx:key="_id"
            class="habit-item {{item.checked ? 'checked' : ''}} {{!tempShowCompleted && item.checked ? 'hidden-item' : ''}}"
            data-habit-id="{{item._id}}">
        <!-- 复选框 -->
        <view class="habit-checkbox {{item.checked ? 'checked' : ''}}"
              bindtap="{{item.checked ? 'onUncheckin' : 'onCheckin'}}"
              data-habit-id="{{item._id}}">
          {{item.checked ? '✓' : ''}}
        </view>

        <!-- 分类徽章 -->
        <view class="category-badge cat-{{item.categoryId}}">{{item.categoryIcon}}</view>

        <!-- 内容 -->
        <view class="habit-content">
          <text class="habit-name">{{item.name}} <text class="important-flag-text" wx:if="{{item.important}}">🚩</text></text>
          <view class="habit-meta">
            <text class="habit-time {{item.timeRule && item.timeRule.fixedTime ? 'has-time' : ''}}" wx:if="{{item.timeRule && item.timeRule.fixedTime}}">{{item.timeRule.fixedTime}}</text>
            <text class="habit-time no-time" wx:else>无固定时间</text>
            <view wx:if="{{item.totalCheckins > 0}}" class="streak-badge">
              🔥 {{item.totalCheckins}}天
            </view>
          </view>
        </view>

        <!-- 编辑删除按钮 -->
        <view class="habit-actions">
          <text class="action-btn edit-btn" bindtap="onEditHabit" data-habit-id="{{item._id}}">✎</text>
          <text class="action-btn delete-btn" bindtap="onDeleteHabit" data-habit-id="{{item._id}}">🗑</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 日历弹窗 -->
  <calendar
    wx:if="{{showCalendar}}"
    year="{{calendarYear}}"
    month="{{calendarMonth}}"
    selectedDate="{{selectedDate}}"
    markedDates="{{checkinDates}}"
    bind:select="onSelectDate"
    bind:close="onCloseCalendar"
  />

  <!-- 自定义底部导航 -->
  <custom-tabbar currentPage="pages/index/index" />
</view>
