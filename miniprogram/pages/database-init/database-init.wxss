.container {
  padding: 60rpx 40rpx 40rpx;
  padding-top: calc(60rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 状态区域 */
.status-section {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
  display: block;
}

.collection-list {
  margin-bottom: 32rpx;
}

.collection-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 6rpx solid #ddd;
  transition: all 0.3s;
}

.collection-item.status-ready {
  border-left-color: #10b981;
  background: #ecfdf5;
}

.collection-item.status-not_ready {
  border-left-color: #f59e0b;
  background: #fffbeb;
}

.collection-item.status-checking {
  border-left-color: #3b82f6;
  background: #eff6ff;
}

.collection-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collection-info {
  flex: 1;
}

.collection-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.collection-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.collection-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: block;
  margin-bottom: 4rpx;
}

.status-badge.success {
  background: #10b981;
  color: white;
}

.status-badge.pending {
  background: #f59e0b;
  color: white;
}

.status-badge.checking {
  background: #3b82f6;
  color: white;
}

.status-count {
  font-size: 22rpx;
  color: #999;
}

.refresh-btn {
  width: 100%;
  height: 88rpx;
  background: #3b82f6;
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 操作区域 */
.actions-section {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.init-btn, .preset-btn {
  width: 100%;
  height: auto;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  border: none;
  position: relative;
  overflow: hidden;
}

.preset-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.init-btn::after, .preset-btn::after {
  content: none;
}

.btn-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.btn-text {
  flex: 1;
  text-align: left;
}

.btn-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.btn-desc {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
}

.btn-check {
  position: absolute;
  right: 0;
  top: 0;
  width: 80rpx;
  height: 100%;
  background: rgba(16, 185, 129, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 48rpx;
  color: #10b981;
}

/* 结果区域 */
.result-section {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.result-box {
  background: #f0fdf4;
  border: 2rpx solid #10b981;
  border-radius: 16rpx;
  padding: 32rpx;
}

.result-box.success {
  background: #f0fdf4;
  border-color: #10b981;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #10b981;
  display: block;
  margin-bottom: 24rpx;
}

.result-details {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-item {
  font-size: 28rpx;
  color: #065f46;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(16, 185, 129, 0.2);
}

.result-item.skipped {
  color: #b45309;
  border-bottom-color: rgba(180, 83, 9, 0.2);
}

.result-item.error {
  color: #dc2626;
  border-bottom-color: rgba(220, 38, 38, 0.2);
}

/* 说明区域 */
.info-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 32rpx;
  backdrop-filter: blur(10rpx);
}

.info-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.info-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}
