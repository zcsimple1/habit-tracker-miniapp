<view class="card">
  <view class="title">{{isEdit ? '编辑习惯' : '新建习惯'}}</view>
  <view style="margin-top: 20rpx;">
    <input placeholder="习惯名称，例如：早起/跑步/读书" value="{{name}}" bindinput="onName" />
  </view>
  <view class="muted" style="margin-top: 12rpx;">提示：本版本默认每天一次打卡。</view>

  <view style="margin-top: 24rpx; display:flex; gap: 16rpx;">
    <button type="primary" bindtap="onSave">保存</button>
    <button wx:if="{{isEdit}}" type="warn" bindtap="onDelete">删除</button>
  </view>
</view>
