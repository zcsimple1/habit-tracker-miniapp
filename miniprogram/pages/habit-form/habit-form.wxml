<view class="container">
  <!-- 头部 -->
  <view class="header">
    <button class="header-btn cancel" bindtap="onCancel">取消</button>
    <view class="header-title">{{habitId ? '编辑打卡' : '添加打卡'}}</view>
    <button class="header-btn save" bindtap="onSave" disabled="{{loading}}">保存</button>
  </view>

  <!-- 表单内容 -->
  <view class="content">
    <!-- 任务标题 -->
    <view class="form-group">
      <view class="form-label">任务标题 <text class="required">*</text></view>
      <input
        class="form-input"
        placeholder="输入习惯名称..."
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="30"
      />
    </view>

    <!-- 任务描述 -->
    <view class="form-group">
      <view class="form-label">任务描述</view>
      <textarea
        class="form-textarea"
        placeholder="添加详细说明（可选）"
        value="{{description}}"
        bindinput="onDescInput"
        maxlength="100"
      />
    </view>

    <!-- 所属分类 -->
    <view class="form-group">
      <view class="form-label">所属分类 <text class="required">*</text></view>
      <picker mode="selector" range="{{categories}}" range-key="displayName" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="form-picker">
          <text>{{categoryName}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 循环规则 -->
    <view class="form-group">
      <view class="form-label">循环规则 <text class="required">*</text></view>
      <view class="radio-group">
        <view
          class="radio-option {{timeRuleTypeIndex === 0 ? 'active' : ''}}"
          bindtap="onTimeRuleTypeChange"
          data-index="0"
        >
          <text class="radio-icon">📅</text> 每日
        </view>
        <view
          class="radio-option {{timeRuleTypeIndex === 1 ? 'active' : ''}}"
          bindtap="onTimeRuleTypeChange"
          data-index="1"
        >
          <text class="radio-icon">💼</text> 工作日
        </view>
        <view
          class="radio-option {{timeRuleTypeIndex === 2 ? 'active' : ''}}"
          bindtap="onTimeRuleTypeChange"
          data-index="2"
        >
          <text class="radio-icon">🎪</text> 周末
        </view>
        <view
          class="radio-option {{timeRuleTypeIndex === 3 ? 'active' : ''}}"
          bindtap="onTimeRuleTypeChange"
          data-index="3"
        >
          <text class="radio-icon">📆</text> 每周
        </view>
      </view>

      <!-- 每周选择（仅在 weekly 模式下显示） -->
      <view wx:if="{{timeRuleTypeIndex === 3}}" class="weekday-selector">
        <view class="form-label">选择星期几</view>
        <view class="weekday-options">
          <view class="weekday-option {{weekdayMon ? 'active' : ''}}" bindtap="onWeekDayToggle" data-day="1">一</view>
          <view class="weekday-option {{weekdayTue ? 'active' : ''}}" bindtap="onWeekDayToggle" data-day="2">二</view>
          <view class="weekday-option {{weekdayWed ? 'active' : ''}}" bindtap="onWeekDayToggle" data-day="3">三</view>
          <view class="weekday-option {{weekdayThu ? 'active' : ''}}" bindtap="onWeekDayToggle" data-day="4">四</view>
          <view class="weekday-option {{weekdayFri ? 'active' : ''}}" bindtap="onWeekDayToggle" data-day="5">五</view>
          <view class="weekday-option {{weekdaySat ? 'active' : ''}}" bindtap="onWeekDayToggle" data-day="6">六</view>
          <view class="weekday-option {{weekdaySun ? 'active' : ''}}" bindtap="onWeekDayToggle" data-day="7">日</view>
        </view>
      </view>
    </view>

    <!-- 固定打卡时间 -->
    <view class="form-group">
      <view class="toggle-row">
        <view>
          <view class="toggle-label">固定打卡时间</view>
          <view class="toggle-desc">设置后会在固定时间提醒</view>
        </view>
        <view class="toggle-switch {{showTimeInput ? 'active' : ''}}" bindtap="onToggleTimeInput"></view>
      </view>

      <view wx:if="{{showTimeInput}}" class="time-inputs">
        <picker mode="time" value="{{timeRule.fixedTime}}" bindchange="onTimePickerConfirm">
          <view class="form-input">{{timeRule.fixedTime || '选择时间'}}</view>
        </picker>
      </view>
    </view>

    <!-- 有效期 -->
    <view class="form-group">
      <view class="toggle-row">
        <view>
          <view class="toggle-label">设置有效期</view>
          <view class="toggle-desc">仅在有效期内显示此习惯</view>
        </view>
        <view class="toggle-switch {{showDateInput ? 'active' : ''}}" bindtap="onToggleDateInput"></view>
      </view>

      <view wx:if="{{showDateInput}}" class="date-inputs">
        <picker mode="date" value="{{timeRule.startDate}}" start="2024-01-01" end="2099-12-31" bindchange="onStartDateChange">
          <view class="form-input">{{timeRule.startDate || '选择开始日期'}}</view>
        </picker>
        <picker mode="date" value="{{timeRule.endDate}}" start="2024-01-01" end="2099-12-31" bindchange="onEndDateChange">
          <view class="form-input">{{timeRule.endDate || '选择结束日期'}}</view>
        </picker>
      </view>
    </view>

    <!-- 重要标记 -->
    <view class="form-group">
      <view class="toggle-row">
        <text class="toggle-label">
          <text class="important-flag">🚩</text>
          标记为重要
        </text>
        <view class="toggle-switch {{important ? 'active' : ''}}" bindtap="onImportantToggle"></view>
      </view>
    </view>
  </view>
</view>
