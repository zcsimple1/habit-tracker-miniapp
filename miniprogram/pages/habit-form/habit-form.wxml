<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-left">
      <text class="cancel-btn" bindtap="onCancel">取消</text>
    </view>
    <text class="title">{{habitId ? '编辑习惯' : '新建习惯'}}</text>
    <view class="header-right"></view>
  </view>

  <!-- 表单 -->
  <view class="form">
    <!-- 习惯名称 -->
    <view class="form-item">
      <view class="label">习惯名称</view>
      <input
        class="input"
        placeholder="例如：早起/跑步/读书"
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="30"
      />
    </view>

    <!-- 描述 -->
    <view class="form-item vertical">
      <view class="label">描述（可选）</view>
      <textarea
        class="textarea"
        placeholder="输入描述信息"
        value="{{description}}"
        bindinput="onDescInput"
        maxlength="100"
      />
    </view>

    <!-- 所属分类 -->
    <view class="form-item">
      <view class="label">所属分类</view>
      <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker">{{categoryName}}</view>
      </picker>
    </view>

    <!-- 时间规则 -->
    <view class="form-section">
      <view class="section-title">时间规则</view>

      <!-- 规则类型 -->
      <view class="form-item">
        <view class="label">重复规则</view>
        <picker mode="selector" range="{{['每日', '仅工作日', '仅周末', '每周指定日期', '自定义日期']}}" value="{{timeRuleTypeIndex}}" bindchange="onTimeRuleTypeChange">
          <view class="picker">{{timeRuleTypeText}}</view>
        </picker>
      </view>

      <!-- 每周指定日期 -->
      <view wx:if="{{timeRule.type === 'weekly'}}" class="week-days">
        <view
          wx:for="{{[1,2,3,4,5,6,7]}}"
          wx:key="*this"
          class="week-day {{timeRule.weekDays.includes(item) ? 'active' : ''}}"
          bindtap="onWeekDayToggle"
          data-day="{{item}}"
        >
          {{['','一','二','三','四','五','六','日'][item]}}
        </view>
      </view>

      <!-- 固定时间 -->
      <view class="form-item">
        <view class="label">固定时间（可选）</view>
        <view class="time-picker-row">
          <input
            class="input"
            placeholder="如: 08:00"
            value="{{timeRule.fixedTime}}"
            bindinput="onFixedTimeChange"
          />
          <button class="time-btn" size="mini" bindtap="onShowTimePicker">选择时间</button>
        </view>
      </view>

      <!-- 时间选择器 -->
      <picker
        wx:if="{{showTimePicker}}"
        mode="time"
        value="{{timeRule.fixedTime}}"
        bindchange="onTimePickerConfirm"
        bindcancel="onTimePickerCancel"
      />

      <!-- 有效期 -->
      <view class="form-section-inner">
        <view class="form-item">
          <view class="label">开始日期（可选）</view>
          <picker mode="date" value="{{timeRule.startDate}}" bindchange="onStartDateChange">
            <view class="picker">{{timeRule.startDate || '选择开始日期'}}</view>
          </picker>
        </view>

        <view class="form-item">
          <view class="label">结束日期（可选）</view>
          <picker mode="date" value="{{timeRule.endDate}}" bindchange="onEndDateChange">
            <view class="picker">{{timeRule.endDate || '选择结束日期'}}</view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 重要标记 -->
    <view class="form-item">
      <view class="label">标记为重要</view>
      <view class="important-info">
        <switch checked="{{important}}" bindchange="onImportantChange" />
        <text class="important-text">重要习惯会显示小红旗标识</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-actions">
    <button wx:if="{{habitId}}" class="delete-btn" bindtap="onDelete" disabled="{{loading}}">
      删除习惯
    </button>
    <button class="save-btn" bindtap="onSave" disabled="{{loading}}">
      {{loading ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
