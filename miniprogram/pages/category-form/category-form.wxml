<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="title">{{categoryId ? '编辑分类' : '新建分类'}}</text>
  </view>

  <!-- 表单 -->
  <view class="form">
    <!-- 分类名称 -->
    <view class="form-item">
      <view class="label">分类名称</view>
      <input
        class="input"
        placeholder="输入分类名称"
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="20"
      />
    </view>

    <!-- 图标选择 -->
    <view class="form-section">
      <view class="section-title">选择图标</view>
      <view class="icon-grid">
        <view
          wx:for="{{icons}}"
          wx:key="*this"
          class="icon-item {{icon === item ? 'active' : ''}}"
          bindtap="onIconSelect"
          data-icon="{{item}}"
        >
          <text class="icon-text">{{item}}</text>
          <view wx:if="{{icon === item}}" class="icon-check">✓</view>
        </view>
      </view>
    </view>

    <!-- 颜色选择 -->
    <view class="form-section">
      <view class="section-title">选择颜色</view>
      <view class="color-grid">
        <view
          wx:for="{{colors}}"
          wx:key="*this"
          class="color-item {{color === item ? 'active' : ''}}"
          style="background-color: {{item}}"
          bindtap="onColorSelect"
          data-color="{{item}}"
        >
          <view wx:if="{{color === item}}" class="color-check">✓</view>
        </view>
      </view>
    </view>

    <!-- 预览 -->
    <view class="preview-section">
      <view class="section-title">预览</view>
      <view class="preview-card" style="background-color: {{color}}">
        <view class="preview-icon">{{icon || '?'}}</view>
        <view class="preview-name">{{name || '分类名称'}}</view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="bottom-actions">
    <button class="save-btn" bindtap="onSave" disabled="{{loading}}">
      {{loading ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
