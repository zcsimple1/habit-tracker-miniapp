<view class="container">
  <!-- 头部 -->
  <view class="header">
    <button class="header-btn cancel" bindtap="onCancel">取消</button>
    <view class="header-title">{{categoryId ? '编辑分类' : '新建分类'}}</view>
    <button class="header-btn save" bindtap="onSave" disabled="{{loading}}">保存</button>
  </view>

  <!-- 表单内容 -->
  <view class="content">
    <!-- 分类名称 -->
    <view class="form-group">
      <view class="form-label">名称 <text class="required">*</text></view>
      <input
        class="form-input"
        placeholder="输入分类名称..."
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="20"
      />
    </view>

    <!-- 图标选择 -->
    <view class="form-group">
      <view class="form-label">图标 <text class="required">*</text></view>
      <view class="icon-grid">
        <view
          wx:for="{{icons}}"
          wx:key="*this"
          class="icon-item {{icon === item ? 'active' : ''}}"
          bindtap="onIconSelect"
          data-icon="{{item}}"
        >
          <text class="icon-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 颜色选择 -->
    <view class="form-group">
      <view class="form-label">颜色</view>
      <view class="color-grid">
        <view
          wx:for="{{colors}}"
          wx:key="*this"
          class="color-item {{color === item ? 'active' : ''}}"
          style="background-color: {{item}}"
          bindtap="onColorSelect"
          data-color="{{item}}"
        >
          <text wx:if="{{color === item}}" class="color-check">✓</text>
        </view>
      </view>
    </view>

    <!-- 预览 -->
    <view class="form-group preview-section">
      <view class="form-label">预览</view>
      <view class="preview-card" style="background-color: {{color}}">
        <text class="preview-icon">{{icon || '?'}}</text>
        <text class="preview-name">{{name || '分类名称'}}</text>
      </view>
    </view>
  </view>
</view>
