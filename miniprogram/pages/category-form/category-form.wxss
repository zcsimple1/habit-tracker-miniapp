.container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 120rpx 30rpx 20rpx;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-title {
  font-size: 18px;
  font-weight: 600;
  color: white;
}

.header-btn {
  background: none;
  border: none;
  color: white;
  font-size: 16px;
  font-weight: 600;
  padding: 8px 16px;
  border-radius: 8px;
  margin: 0;
}

.header-btn::after {
  border: none;
}

.header-btn.save {
  background: rgba(255, 255, 255, 0.25);
}

.header-btn.cancel:active {
  background: rgba(255, 255, 255, 0.15);
}

.header-btn.save:active {
  background: rgba(255, 255, 255, 0.4);
}

/* 内容区 */
.content {
  padding: 0;
  background: #f8f9fa;
}

/* 表单组 */
.form-group {
  background: white;
  padding: 16px;
  margin-bottom: 1px;
}

.form-label {
  font-size: 13px;
  font-weight: 600;
  color: #666;
  margin-bottom: 12px;
  display: block;
}

.required {
  color: #ef4444;
}

.form-input {
  width: 100%;
  border: 2px solid #e5e7eb;
  border-radius: 10px;
  padding: 14px;
  font-size: 15px;
  background: white;
  box-sizing: border-box;
  height: 48px;
  line-height: 1.5;
}

/* 图标网格 */
.icon-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.icon-item {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.icon-item.active {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.1);
}

.icon-text {
  font-size: 24px;
}

/* 颜色网格 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.color-item {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 3px solid transparent;
  transition: all 0.2s;
}

.color-item.active {
  border-color: #333;
  transform: scale(1.1);
}

.color-check {
  color: white;
  font-size: 18px;
  font-weight: 700;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
}

/* 预览 */
.preview-section {
  margin-top: 20px;
}

.preview-card {
  border-radius: 16px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.preview-icon {
  font-size: 32px;
  width: 56px;
  height: 56px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-name {
  font-size: 18px;
  font-weight: 600;
  color: white;
}
