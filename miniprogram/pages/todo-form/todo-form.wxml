<view class="container">
  <!-- 头部 -->
  <view class="header">
    <button class="header-btn cancel" bindtap="onCancel">取消</button>
    <view class="header-title">{{todoId ? '编辑待办' : '添加待办'}}</view>
    <button class="header-btn save" bindtap="onSave" disabled="{{loading}}">保存</button>
  </view>

  <!-- 表单内容 -->
  <view class="form-content">
    <!-- 任务标题 -->
    <view class="form-group">
      <view class="form-label">任务标题 <text class="required">*</text></view>
      <input
        class="form-input"
        placeholder="输入待办事项..."
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="50"
      />
    </view>

    <!-- 任务描述 -->
    <view class="form-group">
      <view class="form-label">任务描述</view>
      <textarea
        class="form-textarea"
        placeholder="添加详细说明（可选）"
        value="{{description}}"
        bindinput="onDescInput"
        maxlength="200"
      />
    </view>

    <!-- 优先级 -->
    <view class="form-group">
      <view class="form-label">优先级</view>
      <view class="priority-options">
        <view
          class="priority-option low {{priority === 'low' ? 'active' : ''}}"
          bindtap="onPriorityTap"
          data-priority="low"
        >低</view>
        <view
          class="priority-option normal {{priority === 'normal' ? 'active' : ''}}"
          bindtap="onPriorityTap"
          data-priority="normal"
        >普通</view>
        <view
          class="priority-option high {{priority === 'high' ? 'active' : ''}}"
          bindtap="onPriorityTap"
          data-priority="high"
        >重要</view>
        <view
          class="priority-option urgent {{priority === 'urgent' ? 'active' : ''}}"
          bindtap="onPriorityTap"
          data-priority="urgent"
        >紧急</view>
      </view>
    </view>

    <!-- 截止日期和时间 -->
    <view class="form-row">
      <view class="form-col">
        <view class="form-group">
          <view class="form-label">截止日期</view>
          <picker mode="date" value="{{dueDate}}" bindchange="onDueDateChange">
            <view class="form-input picker-input">{{dueDate}}</view>
          </picker>
        </view>
      </view>
      <view class="form-col">
        <view class="form-group">
          <view class="form-label">截止时间</view>
          <picker mode="time" value="{{dueTime}}" bindchange="onDueTimeChange">
            <view class="form-input picker-input">{{dueTime || '选择时间'}}</view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 重要标记 -->
    <view class="form-group">
      <view class="toggle-row">
        <text class="toggle-label"><text class="important-flag">🚩</text> 标记为重要</text>
        <view class="toggle-switch {{important ? 'active' : ''}}" bindtap="onImportantToggle"></view>
      </view>
    </view>
  </view>
</view>
