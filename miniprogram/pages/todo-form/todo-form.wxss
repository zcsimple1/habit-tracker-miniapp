/* 引入公共表单样式 */
@import '../../styles/form.wxss';

.container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 120rpx 30rpx 20rpx;
  padding-top: calc(120rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
}

.header-btn {
  background: rgba(255, 255, 255, 0.2);
  border: none;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  margin: 0;
}

.header-btn::after {
  border: none;
}

.header-btn.save {
  background: rgba(255, 255, 255, 0.3);
}

.header-btn.cancel:active {
  background: rgba(255, 255, 255, 0.3);
}

.header-btn.save:active {
  background: rgba(255, 255, 255, 0.45);
}
