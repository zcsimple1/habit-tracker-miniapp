/* 引入公共表单样式 */
@import '../../styles/form.wxss';

.container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 30rpx 16rpx;
  padding-top: calc(100rpx + env(safe-area-inset-top));
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: white;
}

.header-btn {
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  margin: 0;
}

.header-btn::after {
  border: none;
}

.header-btn.save {
  background: rgba(255, 255, 255, 0.25);
}

.header-btn.cancel:active {
  background: rgba(255, 255, 255, 0.25);
}

.header-btn.save:active {
  background: rgba(255, 255, 255, 0.4);
}
